@page "/"
@using System.Linq
@using Microsoft.EntityFrameworkCore
@using ProjectWebsite10032026.Data
@using ProjectWebsite10032026.Models

@inject IJSRuntime JS
@inject AppDbContext Db

<style>
    body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
    }

    .layout {
        display: flex;
        height: 100vh;
    }

    .sidebar {
        width: 260px;
        background: #0f172a;
        color: white;
        padding: 30px;
        display: flex;
        flex-direction: column;
    }

    .logo {
        font-size: 40px;
        font-weight: bold;
        margin-bottom: 40px;
    }

    .sidebar button {
        margin-bottom: 15px;
        padding: 12px;
        background: #1e293b;
        color: white;
        border: none;
        cursor: pointer;
        font-size: 16px;
    }

        .sidebar button:hover {
            background: #334155;
        }

    .content {
        flex: 1;
        padding: 40px;
        overflow-y: auto;
    }

    section {
        margin-top: 40px;
    }

    .card {
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 6px;
        margin-top: 10px;
    }

        .card a {
            text-decoration: none;
            font-size: 18px;
            color: #2563eb;
        }
</style>

<div class="layout">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="logo">Mercantec</div>

        <button @onclick='() => ScrollToSection("links")'>
            Links
        </button>

        <button @onclick='() => ScrollToSection("pdfs")'>
            PDF Files
        </button>
    </div>

    <!-- Content -->
    <div class="content">

        <h1>Resource Portal</h1>
        <p>Access useful links and PDF files.</p>

        <!-- LINKS -->
        <section id="links">
            <h2>Useful Links</h2>

            @foreach (var item in links)
            {
                <div class="card">
                    <a href="@item.Url" target="_blank">
                        @item.Description
                    </a>
                </div>
            }
        </section>

        <!-- PDF FILES -->
        <section id="pdfs">
            <h2>PDF Files</h2>

            @foreach (var item in downloads)
            {
                <div class="card">
                    <a href="@item.FilePath" target="_blank">
                        @item.Description
                    </a>
                </div>
            }
        </section>

    </div>
</div>

@code {

    List<Link> links = new();
    List<Download> downloads = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            links = await Db.Links.ToListAsync();
            downloads = await Db.Downloads.ToListAsync();
        }
        catch
        {
            links = new();
            downloads = new();
        }
    }

    async Task ScrollToSection(string id)
    {
        await JS.InvokeVoidAsync("eval",
            $"document.getElementById('{id}').scrollIntoView({{behavior:'smooth'}})");
    }
}
